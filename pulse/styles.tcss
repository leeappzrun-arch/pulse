/* Layout only — colours are applied at runtime from the detected theme */

Screen {
    layout: vertical;
}

#logo {
    width: 100%;
    height: auto;
    text-align: center;
    padding: 1 2 0 2;
    background: transparent;
}

#main-row {
    layout: horizontal;
    height: 3fr;
    width: 100%;
}

#secondary-row {
    layout: horizontal;
    height: 2fr;
    width: 100%;
}

ArcGauge {
    width: 1fr;
    height: 100%;
}
